{
  "name": "app",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "npm run env:dev && astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "generate-types": "wrangler types",
    "check": "rm -rf .astro && astro check",
    "env:mirror": "tsx scripts/mirror-public-auth.ts",
    "env:dev": "neon checkout dev && npm run env:mirror -- --file .env",
    "env:prod": "neon env pull --branch main --file .env.production && npm run env:mirror -- --file .env.production",
    "db:status": "dbmate --url \"$DATABASE_URL\" --migrations-dir ../database/migrations status",
    "db:migrate": "dbmate --url \"$DATABASE_URL\" --migrations-dir ../database/migrations up",
    "db:seed": "tsx scripts/seed.ts",
    "seed:dev-auth": "tsx --env-file=.env scripts/seed-dev-auth.ts",
    "db:introspect": "drizzle-kit introspect --config drizzle.config.ts",
    "smoke": "tsx scripts/smoke.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "validate:app": "npm run db:status && npm run db:migrate && npm run db:introspect && npx fallow && npm test && npm run check && bash ../scripts/refresh-graph.sh",
    "prepare": "cd .. && husky"
  },
  "lint-staged": {
    "*": "prettier --write --ignore-unknown"
  },
  "dependencies": {
    "@alpinejs/persist": "^3.15.12",
    "@astrojs/alpinejs": "^1.0.0",
    "@astrojs/check": "^0.9.9",
    "@astrojs/cloudflare": "^14.1.1",
    "@astrojs/ts-plugin": "^1.10.10",
    "@neon/config": "^0.9.1",
    "@neon/env": "^0.10.1",
    "@neondatabase/neon-js": "^0.6.2-beta",
    "@neondatabase/serverless": "^1.1.0",
    "@tailwindcss/vite": "^4.3.2",
    "@types/alpinejs": "^3.13.11",
    "alpinejs": "^3.15.12",
    "astro": "^7.0.6",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "jose": "^6.2.3",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "dbmate": "^2.33.0",
    "drizzle-kit": "^0.31.10",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.2.0",
    "postgres": "^3.4.9",
    "prettier": "3.9.6",
    "prettier-plugin-astro": "0.14.1",
    "tsx": "^4.23.0",
    "vitest": "^4.1.10",
    "wrangler": "^4.114.0"
  }
}
