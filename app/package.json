{
  "name": "app",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "generate-types": "wrangler types",
    "check": "astro check",
    "db:status": "dbmate --url \"$DATABASE_URL_POOLED\" --migrations-dir ../database/migrations status",
    "db:migrate": "dbmate --url \"$DATABASE_URL_POOLED\" --migrations-dir ../database/migrations up",
    "db:seed": "tsx scripts/seed.ts",
    "db:introspect": "drizzle-kit introspect --config drizzle.config.ts",
    "smoke": "tsx scripts/smoke.ts",
    "validate:app": "npm run db:status && npm run db:migrate && npm run db:introspect && npx fallow && astro check && bash ../scripts/refresh-graph.sh"
  },
  "dependencies": {
    "@astrojs/alpinejs": "^1.0.0",
    "@astrojs/check": "^0.9.9",
    "@astrojs/cloudflare": "^14.1.1",
    "@astrojs/ts-plugin": "^1.10.10",
    "@neon/config": "^0.9.1",
    "@neon/env": "^0.10.1",
    "@neondatabase/serverless": "^1.1.0",
    "@tailwindcss/vite": "^4.3.2",
    "@types/alpinejs": "^3.13.11",
    "alpinejs": "^3.15.12",
    "astro": "^7.0.6",
    "drizzle-orm": "^0.45.2",
    "jose": "^6.2.3",
    "tailwindcss": "^4.3.2",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^6.0.3",
    "wrangler": "^4.107.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "dbmate": "^2.33.0",
    "drizzle-kit": "^0.31.10",
    "postgres": "^3.4.9",
    "tsx": "^4.23.0"
  }
}
