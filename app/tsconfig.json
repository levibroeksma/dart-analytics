{
  "extends": "astro/tsconfigs/strict",
  "include": [".astro/types.d.ts", "**/*", "./worker-configuration.d.ts"],
  "exclude": ["dist"],
  "compilerOptions": {
    "types": ["node"],
    "paths": {
      "@icons/*": ["./src/icons/*"],
      "@components/*": ["./src/components/*"],
      "@layouts/*": ["./src/layouts/*"],
      "@pages/*": ["./src/pages/*"],
      "@lib/*": ["./src/lib/*"],
      "@client/*": ["./src/lib/client/*"],
      "@auth/*": ["./src/lib/auth/*"],
      "@server/*": ["./src/lib/server/*"],
      "@stores/*": ["./src/stores/*"],
      "@forms/*": ["./src/forms/*"],
      "@types/*": ["./src/types/*"],
      "@modules/*": ["./src/modules/*"],
      "@utils/*": ["./src/lib/utils/*"],
      "@styles/*": ["./src/styles/*"]
    }
  }
}
