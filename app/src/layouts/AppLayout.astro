---
import BaseLayout from "@layouts/BaseLayout.astro";
import BottomNav from "@components/layout/BottomNav.astro";

interface Props {
  title?: string;
}

const { title } = Astro.props;
---

<BaseLayout title={title}>
  <div class="app-shell">
    <main class="app-main">
      <slot />
    </main>
    <BottomNav />
  </div>
</BaseLayout>
