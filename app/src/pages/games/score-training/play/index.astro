---
export const prerender = true;
import GameLayout from "@layouts/GameLayout.astro";
import Button from "@components/forms/Button.astro";
import ScoreTraining from "@components/layout/games/interfaces/ScoreTraining.astro";
import ConfirmDialog from "@components/ui/ConfirmDialog.astro";
import ScoreTrainingResults from "@components/layout/games/result-modals/ScoreTrainingResults.astro";
import NoSessionPanel from "@components/layout/games/NoSessionPanel.astro";
---

<GameLayout title="Score Training — Play">
  <div
    class="flex flex-col flex-1 min-h-0 p-3"
    x-data="scoreTrainingPlay()"
    @confirm-exit.window="abandonAndExit()"
  >
    {/* Loading / reconciliation-blocked */}
    <div class="text-center py-8" x-show="loadingReconciliation || reconciliationFailed" x-cloak>
      <p class="text-sm text-muted-foreground" x-show="loadingReconciliation" x-cloak>Loading...</p>
      <div x-show="reconciliationFailed && !loadingReconciliation" x-cloak>
        <p class="text-sm text-error">Could not clean up a previous session. Retry to continue.</p>
        <Button type="button" class="mt-4" @click="retryReconciliation()">
          Retry
        </Button>
      </div>
    </div>

    {/* No active session view */}
    <NoSessionPanel />

    {/* Gameplay view */}
    <ScoreTraining x-show="!finished && hasActiveSession" x-cloak />

    {/* Finish confirm (before results) */}
    <div x-show="showFinishConfirm" x-cloak>
      <ConfirmDialog
        titleId="finish-confirm-title"
        title="Finish session?"
        description="This visit completes the session. Confirm to save, or cancel to adjust the score."
        confirmLabel="Confirm"
        onCancel="cancelFinish()"
        onConfirm="confirmFinish()"
        dismissible={false}
      />
    </div>

    {/* Results modal (overlay) */}
    <ScoreTrainingResults />
  </div>
</GameLayout>
