---
export const prerender = true;
import BaseLayout from "@layouts/BaseLayout.astro";
import { env } from "../lib/env";

const signInUrl = `${env.auth.baseUrl}/sign-in`;
---

<BaseLayout title="Login">
  <div class="app-shell">
    <main class="app-main flex flex-col justify-center p-6">
      <div class="mx-auto w-full max-w-md space-y-4">
        <h1 class="text-2xl font-semibold text-fg">Sign in</h1>
        <p class="text-sm text-fg-muted">
          Authenticate with Neon Auth to access your profile.
        </p>
        <a class="btn btn-primary w-full" href={signInUrl}>
          Continue to Neon Auth
        </a>
      </div>
    </main>
  </div>
</BaseLayout>
