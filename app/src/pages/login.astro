---
export const prerender = true;
import BaseLayout from "@layouts/BaseLayout.astro";
import { env } from "../lib/env";

const signInUrl = `${env.auth.baseUrl}/sign-in`;
---

<BaseLayout title="Login">
  <main class="mx-auto flex min-h-[60vh] max-w-md flex-col justify-center gap-4 p-6">
    <h1 class="text-2xl font-semibold">Sign in</h1>
    <p class="text-sm text-neutral-600">
      Authenticate with Neon Auth to access your profile.
    </p>
    <a
      class="inline-flex items-center justify-center rounded-md bg-neutral-900 px-4 py-2 text-white"
      href={signInUrl}
    >
      Continue to Neon Auth
    </a>
  </main>
</BaseLayout>
