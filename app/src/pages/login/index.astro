---
export const prerender = true;
import BaseLayout from "@layouts/BaseLayout.astro";
import Input from "@components/forms/Input.astro";
import Button from "@components/forms/Button.astro";
import LoadingIcon from "@icons/loading.svg";
---

<BaseLayout>
  <div class="mx-auto flex h-full max-w-lg flex-col">
    <main
      class="flex min-h-0 flex-1 flex-col overflow-y-auto overscroll-y-contain justify-center p-6"
    >
      <div
        class="glass mx-auto rounded-lg border border-border bg-surface-raised w-full max-w-md space-y-6 p-6"
      >
        <div class="space-y-1">
          <h1 class="text-2xl font-semibold font-display text-accent">
            Darts Analytics
          </h1>
          <p class="text-sm text-foreground">Welcome back!</p>
        </div>

        <form
          x-data="loginForm()"
          @submit.prevent="submit"
          class="flex flex-col gap-4"
        >
          <label
            for="e-mail"
            class="text-xs text-foreground tracking-widest"
          >
            <span class="font-semibold"> Email </span>
            <Input
              label="Email"
              type="email"
              name="email"
              autocomplete="email"
              placeholder="example@email.com"
              x-model="email"
              required
              class="mt-2"
            />
          </label>

          <label
            for="password"
            class="text-xs text-foreground tracking-widest"
          >
            <span class="font-semibold">Password</span>
            <Input
              label="Password"
              type="password"
              name="password"
              autocomplete="current-password"
              x-model="password"
              required
              class="mt-2"
            />
          </label>
          <p
            x-show="error"
            x-text="error"
            x-cloak
            class="text-sm text-error"
            role="alert"
          >
          </p>
          <Button
            type="submit"
            variant="primary"
            class="w-full mt-4"
            :disabled="loading"
            title="Sign in"
          >
            <LoadingIcon
              x-show="loading"
              x-cloak
              slot="iconAfter"
              class="size-6"
            />
          </Button>
        </form>
      </div>
    </main>
  </div>
</BaseLayout>
