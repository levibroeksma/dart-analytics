---
interface Props {
  score?: string;
  target?: string;
  isTarget?: boolean;
  class?: string;
}

// Props
const { score, target, isTarget = true, class: className = "" }: Props = Astro.props;
---

{
  /** TODO:
   * Add checkout route tips based on configuration (if config.showRoutes && isTarget)
   * Note: config not yet implemented, deferred
   */
}
<div class:list={["flex-1 min-h-0 glass rounded-lg", className]}>
  <div
    class="rounded-lg border border-border bg-surface-raised h-full p-3 mx-auto flex flex-col items-center justify-center"
  >
    <h1
      class="text-7xl font-mono font-bold tabular-nums"
      x-text={isTarget ? target : score}
    ></h1>
    <span class="text-sm text-foreground-muted uppercase">
      {isTarget ? "Target" : "Score"}
    </span>
    {
      /**
       * TODO: progress slot — darts thrown, 3-dart avg, previous score (per game).
       * Out of scope for Score Training play UI.
       */
    }
    <slot name="progress" />
  </div>
</div>
