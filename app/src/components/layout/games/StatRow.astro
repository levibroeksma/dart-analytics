---
interface Props {
  label: string;
  value: string;
}
const { label, value }: Props = Astro.props;
---

<div class="flex justify-between items-center font-display-mono">
  <dt
    class="text-sm text-muted-foreground"
    x-text={`'${label}:'`}
  >
  </dt>
  <dd
    class="font-mono text-sm font-bold tabular-nums text-foreground"
    x-text={`${value}`}
  >
  </dd>
</div>
