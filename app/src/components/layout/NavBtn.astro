---
interface Props {
  href: string;
  matchPrefix?: string;
  class?: string;
}

// Props
const { href, matchPrefix, class: classNameProp }: Props = Astro.props;

// Lib
import { isNavActive } from "@utils/is-nav-active";

// Styles
const baseClassName =
  "icon-btn-hover btn-press inline-flex items-center justify-center rounded-md p-2 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring disabled:opacity-50 [&_svg]:block [&_svg]:size-6";
const active = isNavActive(Astro.url.pathname, href, matchPrefix);
const className = [
  baseClassName,
  active ? "text-primary" : "nav-link-inactive",
  classNameProp,
]
  .filter(Boolean)
  .join(" ");
---

<a href={href} class={className}>
  <slot />
</a>
