---
/**
 * Pill-style navigation link.
 * @param {string} href Link target
 * @param {string} [class] Extra classes
 */
interface Props {
  href: string;
  class?: string;
}

// Props
const { href, class: classNameProp = "" }: Props = Astro.props;

// Lib
import { cn } from "@client/cn";

// Styles
const className = cn(
  "rounded-sm border border-border px-3.5 py-1.5 text-sm text-muted-foreground nav-pill duration-150 no-underline transition-[color,background-color,border-color]",
  classNameProp,
);
---

<a
  href={href}
  class={className}
>
  <slot />
</a>
