---
/**
 * Custom select (Tailwind Plus el-select) styled for this design system.
 * Pass {@link SelectOption} children via the default slot.
 * @param {string} [id]
 * @param {boolean} [error]
 * @param {boolean} [disabled]
 * @param {string} [ariaDescribedby]
 * @param {string} [class] Extra classes on el-select
 */
interface Props {
  id?: string;
  error?: boolean;
  disabled?: boolean;
  ariaDescribedby?: string;
  class?: string;
}

// Props
const {
  id,
  error = false,
  disabled = false,
  ariaDescribedby,
  class: classNameProp = "",
}: Props = Astro.props;

// Lib
import { cn } from "@client/cn";

// Styles
const className = cn("block w-full", classNameProp);

const buttonClassName = cn(
  "grid w-full cursor-default grid-cols-1 rounded-md bg-white/5 py-2 pr-2 pl-3.5 text-left text-sm text-foreground outline-1 -outline-offset-1 outline-border transition-[outline-color,box-shadow] duration-150",
  "focus-visible:outline-2 focus-visible:-outline-offset-2 focus-visible:outline-accent",
  "disabled:cursor-not-allowed disabled:opacity-40",
  error && "outline-error focus-visible:outline-error",
);
---

<div
  id={id}
  aria-invalid={error ? "true" : undefined}
  aria-describedby={ariaDescribedby}
  class={className}
>
  <button
    type="button"
    disabled={disabled}
    class={buttonClassName}
  >
    <div class="col-start-1 row-start-1 truncate pr-6"></div>
    <svg
      viewBox="0 0 16 16"
      fill="currentColor"
      aria-hidden="true"
      class="col-start-1 row-start-1 size-4 self-center justify-self-end text-muted"
    >
      <path
        d="M5.22 10.22a.75.75 0 0 1 1.06 0L8 11.94l1.72-1.72a.75.75 0 1 1 1.06 1.06l-2.25 2.25a.75.75 0 0 1-1.06 0l-2.25-2.25a.75.75 0 0 1 0-1.06ZM10.78 5.78a.75.75 0 0 1-1.06 0L8 4.06 6.28 5.78a.75.75 0 0 1-1.06-1.06l2.25-2.25a.75.75 0 0 1 1.06 0l2.25 2.25a.75.75 0 0 1 0 1.06Z"
        clip-rule="evenodd"
        fill-rule="evenodd"
      ></path>
    </svg>
  </button>

  <div
    class="max-h-60 w-(--button-width) overflow-auto rounded-md bg-[oklch(14%_0_0)] py-1 text-sm outline-1 -outline-offset-1 outline-border shadow-lg [--anchor-gap:--spacing(1)] data-leave:transition data-leave:transition-discrete data-leave:duration-100 data-leave:ease-in data-closed:data-leave:opacity-0"
  >
    <slot />
  </div>
</div>
