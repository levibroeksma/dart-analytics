---
/**
 * Inline feedback banner.
 * @param {"error"|"success"} variant
 * @param {string} [title]
 * @param {string} [class] Extra classes
 */
interface Props {
  variant: "error" | "success";
  title?: string;
  class?: string;
}

const { variant, title, class: className = "" } = Astro.props;
const isError = variant === "error";
---

<div
  class:list={[
    "alert flex items-start gap-3 rounded-md border px-4 py-3 text-sm",
    isError
      ? "alert-error border-error/40 text-error-foreground"
      : "alert-success border-success/40 text-foreground",
    className,
  ]}
  role={isError ? "alert" : "status"}
>
  {
    isError ? (
      <svg
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="mt-0.5 shrink-0"
        aria-hidden="true"
      >
        <circle cx="12" cy="12" r="10" />
        <line x1="15" y1="9" x2="9" y2="15" />
        <line x1="9" y1="9" x2="15" y2="15" />
      </svg>
    ) : (
      <svg
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="mt-0.5 shrink-0 text-success"
        aria-hidden="true"
      >
        <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" />
        <polyline points="22 4 12 14.01 9 11.01" />
      </svg>
    )
  }
  <div>
    {
      title && (
        <p class:list={["font-medium", !isError && "text-foreground"]}>{title}</p>
      )
    }
    <p
      class:list={[
        title && "mt-0.5",
        isError ? "text-error-foreground/80" : "text-muted-foreground",
      ]}
    >
      <slot />
    </p>
  </div>
</div>
