---
/**
 * Inline feedback banner.
 * @param {"error"|"success"} variant
 * @param {string} [title]
 * @param {string} [class] Extra classes
 */
interface Props {
  variant: "error" | "success";
  title?: string;
  class?: string;
}

// Props
const { variant, title, class: classNameProp = "" }: Props = Astro.props;
const isError = variant === "error";

// Lib
import { cn } from "@client/cn";

// Styles
const className = cn(
  "alert flex items-start gap-3 rounded-md border px-4 py-3 text-sm",
  isError
    ? "alert-error border-error/40 text-error-foreground"
    : "alert-success border-success/40 text-foreground",
  classNameProp,
);

const titleClassName = cn("font-semibold", !isError && "text-foreground");

const bodyClassName = cn(
  title && "mt-0.5",
  isError ? "text-error-foreground/80" : "text-muted-foreground",
);
---

<div class={className} role={isError ? "alert" : "status"}>
  {
    isError ? (
      <svg
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="mt-0.5 shrink-0"
        aria-hidden="true"
      >
        <circle cx="12" cy="12" r="10" />
        <line x1="15" y1="9" x2="9" y2="15" />
        <line x1="9" y1="9" x2="15" y2="15" />
      </svg>
    ) : (
      <svg
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="mt-0.5 shrink-0 text-success"
        aria-hidden="true"
      >
        <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" />
        <polyline points="22 4 12 14.01 9 11.01" />
      </svg>
    )
  }
  <div>
    {title && <p class={titleClassName}>{title}</p>}
    <p class={bodyClassName}>
      <slot />
    </p>
  </div>
</div>
