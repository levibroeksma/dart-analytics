---
/**
 * Multi-line text input.
 * @param {string} [id]
 * @param {string} [name]
 * @param {number} [rows]
 * @param {string} [placeholder]
 * @param {string} [value]
 * @param {boolean} [error]
 * @param {boolean} [required]
 * @param {boolean} [disabled]
 * @param {string} [ariaDescribedby]
 * @param {string} [class] Extra classes
 */
interface Props {
  id?: string;
  name?: string;
  rows?: number;
  placeholder?: string;
  value?: string;
  error?: boolean;
  required?: boolean;
  disabled?: boolean;
  ariaDescribedby?: string;
  class?: string;
}

const {
  id,
  name,
  rows = 4,
  placeholder,
  value,
  error = false,
  required = false,
  disabled = false,
  ariaDescribedby,
  class: className = "",
} = Astro.props;
---

<textarea
  id={id}
  name={name}
  rows={rows}
  placeholder={placeholder}
  required={required}
  disabled={disabled}
  aria-invalid={error ? "true" : undefined}
  aria-describedby={ariaDescribedby}
  class:list={[
    "input resize-y w-full rounded-md border border-border px-3.5 py-2.5 text-sm text-foreground outline-none transition-[border-color,box-shadow,background-color] duration-150 placeholder:text-muted",
    error && "input-error",
    className,
  ]}>{value}</textarea
>
