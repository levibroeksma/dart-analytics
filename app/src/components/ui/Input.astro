---
/**
 * Text-like input with optional error styling.
 * @param {string} [id]
 * @param {string} [type]
 * @param {string} [name]
 * @param {string} [value]
 * @param {string} [placeholder]
 * @param {boolean} [error]
 * @param {boolean} [required]
 * @param {boolean} [disabled]
 * @param {string} [ariaDescribedby]
 * @param {string} [class] Extra classes
 */
interface Props {
  id?: string;
  type?: string;
  name?: string;
  value?: string;
  placeholder?: string;
  error?: boolean;
  required?: boolean;
  disabled?: boolean;
  ariaDescribedby?: string;
  class?: string;
}

const {
  id,
  type = "text",
  name,
  value,
  placeholder,
  error = false,
  required = false,
  disabled = false,
  ariaDescribedby,
  class: className = "",
} = Astro.props;
---

<input
  id={id}
  type={type}
  name={name}
  value={value}
  placeholder={placeholder}
  required={required}
  disabled={disabled}
  aria-invalid={error ? "true" : undefined}
  aria-describedby={ariaDescribedby}
  class:list={[
    "input w-full rounded-md border border-border px-3.5 py-2.5 text-sm text-foreground outline-none transition-[border-color,box-shadow,background-color] duration-150 placeholder:text-muted",
    error && "input-error",
    className,
  ]}
/>
