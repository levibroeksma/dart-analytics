---
/**
 * Individual tab trigger button for Tabs.
 * @param {string} id Tab button id
 * @param {string} controls Id of the panel this tab opens
 * @param {string} [class] Extra classes
 */
interface Props {
  id: string;
  controls: string;
  class?: string;
}

const { id, controls, class: className = "" } = Astro.props;
---

<button
  role="tab"
  id={id}
  aria-controls={controls}
  class:list={[
    "tab rounded-sm px-4 py-2 text-sm font-medium text-muted-foreground transition-[color,background-color,box-shadow] duration-150",
    className,
  ]}
  :aria-selected={`activeTab === '${id}'`}
  @click={`activeTab = '${id}'`}
>
  <slot />
</button>
