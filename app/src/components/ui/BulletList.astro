---
/**
 * Vertical list of bullet rows.
 * @param {string} [class] Extra classes on the ul
 */
interface Props {
  class?: string;
}

// Props
const { class: classNameProp = "" }: Props = Astro.props;

// Lib
import { cn } from "@client/cn";

// Styles
const className = cn("space-y-3", classNameProp);
---

<ul class={className}>
  <slot />
</ul>
