---
/**
 * Bullet list row with leading icon (defaults to check).
 * Pass a custom icon via the `icon` slot.
 * @param {string} [class] Extra classes
 */
interface Props {
  class?: string;
}

// Props
const { class: classNameProp = "" }: Props = Astro.props;

// Components
import CheckIcon from "@icons/check.svg";

// Lib
import { cn } from "@client/cn";

// Styles
const className = cn("flex gap-3 text-sm text-muted-foreground", classNameProp);
---

<li class={className}>
  <span
    class="mt-0.5 flex size-4 shrink-0 items-center justify-center text-foreground"
  >
    {
      Astro.slots.has("icon") ? (
        <slot name="icon" />
      ) : (
        <CheckIcon class="size-4" />
      )
    }
  </span>
  <span class="min-w-0 leading-relaxed">
    <slot />
  </span>
</li>
