---
/**
 * Option for {@link Select} (el-option).
 * @param {string} value Option value submitted with the form
 * @param {string} [class] Extra classes
 */
interface Props {
  value: string;
  class?: string;
}

// Props
const { value, class: classNameProp = "" }: Props = Astro.props;

// Lib
import { cn } from "@client/cn";

// Styles
const className = cn(
  "group/option relative block cursor-default py-2 pr-4 pl-8 text-foreground select-none",
  "focus:bg-accent focus:text-accent-foreground focus:outline-hidden",
  classNameProp,
);
---

<div role="option" data-value={value} class={className}>
  <span
    class="block truncate font-normal group-aria-selected/option:font-semibold"
  >
    <slot />
  </span>
  <span
    class="absolute inset-y-0 left-0 flex items-center pl-1.5 text-accent group-not-aria-selected/option:hidden group-focus/option:text-accent-foreground in-[el-selectedcontent]:hidden"
  >
    <svg
      viewBox="0 0 20 20"
      fill="currentColor"
      aria-hidden="true"
      class="size-5"
    >
      <path
        d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z"
        clip-rule="evenodd"
        fill-rule="evenodd"></path>
    </svg>
  </span>
</div>
