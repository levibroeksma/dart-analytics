---
/**
 * Radio option with adjacent label.
 * @param {string} id
 * @param {string} name Shared group name
 * @param {string} [value]
 * @param {boolean} [checked]
 * @param {boolean} [disabled]
 * @param {string} [class] Extra classes on the row
 */
interface Props {
  id: string;
  name: string;
  value?: string;
  checked?: boolean;
  disabled?: boolean;
  class?: string;
}

// Props
const {
  id,
  name,
  value,
  checked = false,
  disabled = false,
  class: classNameProp = "",
}: Props = Astro.props;

// Lib
import { cn } from "@client/cn";

// Styles
const className = cn("flex items-center gap-2.5", classNameProp);
---

<div class={className}>
  <input
    type="radio"
    id={id}
    name={name}
    value={value}
    checked={checked}
    disabled={disabled}
    class="control size-4 shrink-0 cursor-pointer appearance-none rounded-full border border-border-strong"
  />
  <label
    for={id}
    class="text-sm text-muted-foreground"
  >
    <slot />
  </label>
</div>
