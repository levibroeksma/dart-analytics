---
/**
 * Form field wrapper with label, hint, and error message.
 * @param {string} [label] Visible label text
 * @param {string} [for] Associates label with control id
 * @param {string} [hint] Helper text below the control
 * @param {string} [error] Error message (sets alert role)
 * @param {string} [errorId] Id for aria-describedby on the control
 * @param {string} [class] Extra classes
 */
interface Props {
  label?: string;
  for?: string;
  hint?: string;
  error?: string;
  errorId?: string;
  class?: string;
}

// Props
const {
  label,
  for: htmlFor,
  hint,
  error,
  errorId,
  class: classNameProp = "",
}: Props = Astro.props;

const resolvedErrorId = errorId ?? (htmlFor ? `${htmlFor}-error` : undefined);

// Lib
import { cn } from "@client/cn";

// Styles
const className = cn("flex flex-col gap-1.5", classNameProp);
---

<div class={className}>
  {
    label && (
      <label
        for={htmlFor}
        class="text-sm font-semibold text-foreground"
      >
        {label}
      </label>
    )
  }
  <slot />
  {hint && !error && <p class="text-xs text-muted">{hint}</p>}
  {
    error && (
      <p
        id={resolvedErrorId}
        class="flex items-start gap-1.5 text-sm text-error"
        role="alert"
      >
        <svg
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="mt-0.5 shrink-0"
          aria-hidden="true"
        >
          <circle
            cx="12"
            cy="12"
            r="10"
          />
          <line
            x1="12"
            y1="8"
            x2="12"
            y2="12"
          />
          <line
            x1="12"
            y1="16"
            x2="12.01"
            y2="16"
          />
        </svg>
        {error}
      </p>
    )
  }
</div>
