---
/**
 * Checkbox with adjacent label.
 * @param {string} id
 * @param {string} [name]
 * @param {string} [value]
 * @param {boolean} [checked]
 * @param {boolean} [disabled]
 * @param {string} [class] Extra classes on the row
 */
interface Props {
  id: string;
  name?: string;
  value?: string;
  checked?: boolean;
  disabled?: boolean;
  class?: string;
}

const {
  id,
  name,
  value,
  checked = false,
  disabled = false,
  class: className = "",
} = Astro.props;
---

<div class:list={["flex items-center gap-2.5", className]}>
  <input
    type="checkbox"
    id={id}
    name={name}
    value={value}
    checked={checked}
    disabled={disabled}
    class="control size-4 shrink-0 cursor-pointer appearance-none rounded border border-border-strong"
  />
  <label for={id} class="text-sm text-muted-foreground">
    <slot />
  </label>
</div>
