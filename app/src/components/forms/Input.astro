---
/**
 * Text-like input with optional error styling.
 * @param {string} [id]
 * @param {string} [type]
 * @param {string} [name]
 * @param {string} [value]
 * @param {string} [placeholder]
 * @param {boolean} [error]
 * @param {boolean} [required]
 * @param {boolean} [disabled]
 * @param {string} [ariaDescribedby]
 * @param {string} [class] Extra classes
 */
interface Props {
  id?: string;
  type?: string;
  name?: string;
  value?: string;
  placeholder?: string;
  error?: boolean;
  required?: boolean;
  disabled?: boolean;
  class?: string;
  [key: string]: unknown;
}

// Props
const {
  id,
  type = "text",
  name,
  value,
  placeholder,
  error = false,
  required = false,
  disabled = false,
  class: classNameProp = "",
  ...props
} = Astro.props;

// Lib
import { cn } from "@client/cn";

// Styles
const inputId = id ?? name;
const className = cn(
  "input w-full rounded-md border border-border px-3.5 py-2.5 text-sm text-foreground outline-none transition-[border-color,box-shadow,background-color] duration-150 placeholder:text-muted",
  error && "input-error",
  classNameProp,
);
---

<input
  id={inputId}
  type={type}
  name={name}
  value={value}
  placeholder={placeholder}
  disabled={disabled}
  required={required}
  class={className}
  {...props}
/>
