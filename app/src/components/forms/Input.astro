---
interface Props {
  label: string;
  name: string;
  type?: "text" | "email" | "password" | "search" | "tel" | "url";
  id?: string;
  autocomplete?: string;
  class?: string;
  [key: string]: unknown;
}

// Props
const {
  label,
  name,
  type = "text",
  id,
  autocomplete,
  class: classNameProp,
  ...props
}: Props = Astro.props;

// Lib
import { cn } from "@client/cn";

// Styles
const inputId = id ?? name;
const className = cn("input", classNameProp);
---

<label
  for={inputId}
  class="text-sm text-muted-foreground"
  >{label}</label
>
<input
  id={inputId}
  name={name}
  type={type}
  autocomplete={autocomplete}
  class={className}
  {...props}
/>
