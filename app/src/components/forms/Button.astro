---
/**
 * Button with design-system variants.
 * @param {"button"|"submit"|"reset"} [type]
 * @param {"primary"|"secondary"|"ghost"|"error"} [variant]
 * @param {boolean} [icon] Equal padding on all sides (icon-only / square hit area)
 * @param {boolean} [disabled]
 * @param {string} [ariaLabel] Accessible name (required for icon-only)
 * @param {string} [class] Extra classes
 */
interface Props {
  type?: "button" | "submit" | "reset";
  title?: string;
  variant?: "primary" | "secondary" | "ghost" | "error";
  icon?: boolean;
  disabled?: boolean;
  ariaLabel?: string;
  class?: string;
  [key: string]: unknown;
}

const {
  type = "button",
  title,
  variant = "primary",
  icon = false,
  disabled = false,
  ariaLabel,
  class: className = "",
  ...props
}: Props = Astro.props;

const variantClasses = {
  primary: "border-transparent bg-white text-black btn-primary",
  secondary: "border-border text-foreground btn-secondary",
  ghost: "text-muted-foreground btn-ghost",
  error: "bg-error text-error-foreground btn-error",
}[variant];
---

<button
  type={type}
  disabled={disabled}
  aria-label={ariaLabel}
  class:list={[
    "btn inline-flex items-center justify-center gap-2 rounded-md border border-transparent text-sm font-medium transition-[transform,color,background-color,border-color,box-shadow] duration-150",
    variantClasses,
    icon ? "p-2.5" : "px-4 py-2.5",
    className,
  ]}
  {...props}
>
  <slot name="iconBefore" />
  {title}
  <slot name="iconAfter" />
</button>
